PORT=3000
HOSTER_URL=http://localhost:3000
JWT_SECRET=vozec_secret_jwt_very_secure
TEMPORARY_DELAY=7 # Days

MONGODB_USER=admin
MONGODB_PASSWORD=password

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_PATH=/manager/

API_PATH=/api
API_KEY=first_api_key,second_api_key

# MCP service (exposes Hoster to AI agents over Model Context Protocol)
MCP_PORT=3333
# MCP_HOSTER_API_KEY=  # Defaults to first key in API_KEY when empty
# MCP_AUTH_KEY=        # Bearer/X-API-Key required by HTTP clients of the MCP. Defaults to MCP_HOSTER_API_KEY.