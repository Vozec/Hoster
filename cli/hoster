    def delete_route(self, identifier):
        rid, info = self._require_route(identifier)
        self._request("DELETE", f"/routes/{rid}")
        _ok(f"Deleted: {info['path']}")

    def edit_route(self, identifier, **kwargs):
        rid, info = self._require_route(identifier)
        data = {k: v for k, v in kwargs.items() if v is not None}
        if not data:
            _err("Nothing to update.")
            return
        if "content_type" in data:
            ct = data.pop("content_type")
            data["contentType"] = CONTENT_TYPE_SHORTCUTS.get(ct, ct)
        if "tags" in data and isinstance(data["tags"], str):
            data["tags"] = [t.strip() for t in data["tags"].split(",") if t.strip()]
        if "custom_headers" in data:
            data["customHeaders"] = data.pop("custom_headers")
        if "content_disposition" in data:
            data["contentDisposition"] = data.pop("content_disposition")
        self._request("PUT", f"/routes/{rid}", data)
        _ok(f"Route updated: {info['path']}")

    def clone_route(self, identifier, new_path=None):
        rid, info = self._require_route(identifier)

        route_path = new_path if new_path else self._random_path()
        if not route_path.startswith("/"):
            route_path = "/" + route_path
        data = {
            "path":               route_path,
            "name":               info["name"] + " (copy)",
            "contentType":        info["contentType"],
            "contentEncoding":    info.get("contentEncoding", "text"),
            "content":            info["content"],
            "category":           info["category"],
            "tags":               info.get("tags", []),
            "corsConfig":         info.get("corsConfig", {}),
            "customHeaders":      info.get("customHeaders", []),
            "fileName":           info.get("fileName", ""),
            "contentDisposition": info.get("contentDisposition", ""),
        }
        self._request("POST", "/routes", data)
        _ok(f"Cloned as: {self.server_url}{route_path}")

    def tag_route(self, identifier, tag, remove=False):
        rid, info = self._require_route(identifier)
        tags = list(info.get("tags", []))
        if remove:
            if tag in tags:
                tags.remove(tag)
                self._request("PUT", f"/routes/{rid}", {"tags": tags})
                _ok(f"Tag '{tag}' removed from {info['path']}")
            else:
                _warn(f"Tag '{tag}' not on {info['path']}")
        else:
            if tag not in tags:
                tags.append(tag)
                self._request("PUT", f"/routes/{rid}", {"tags": tags})
                _ok(f"Tag '{tag}' added to {info['path']}")
            else:
                _warn(f"Tag '{tag}' already on {info['path']}")

    def set_cors(self, identifier, origin=None, methods=None,
                 allow_headers=None, disable=False):
        rid, info = self._require_route(identifier)
        cors = dict(info.get("corsConfig", {}))
        if disable:
            cors["enabled"] = False
        else:
            cors["enabled"] = True
            if origin:        cors["allowOrigin"]  = origin
            if methods:       cors["allowMethods"] = methods
            if allow_headers: cors["allowHeaders"] = allow_headers
        self._request("PUT", f"/routes/{rid}", {"corsConfig": cors})
        _ok(f"CORS updated for {info['path']}")

    def set_headers(self, identifier, headers_list, replace=False):
        """headers_list: list of 'Key: Value' strings."""
        rid, info = self._require_route(identifier)
        parsed = []
        for h in headers_list:
            if ":" in h:
                k, _, v = h.partition(":")
                parsed.append({"key": k.strip(), "value": v.strip()})
        existing = [] if replace else list(info.get("customHeaders", []))
        merged = {h["key"]: h["value"] for h in existing}
        for h in parsed:
            merged[h["key"]] = h["value"]
        self._request("PUT", f"/routes/{rid}", {
            "customHeaders": [{"key": k, "value": v} for k, v in merged.items()]
        })
        _ok(f"Custom headers updated for {info['path']}")

    def test_route(self, identifier, method="GET", body=None, extra_headers=None):
        _, info = self._require_route(identifier)
        url = f"{self.server_url}{info['path']}"
        kwargs = {"timeout": 10}
        if body and method != "GET":
            try:    kwargs["json"] = json.loads(body)
            except: kwargs["data"] = body
        if extra_headers:
            h = {}
            for hdr in extra_headers:
                if ":" in hdr:
                    k, _, v = hdr.partition(":")
                    h[k.strip()] = v.strip()
            kwargs["headers"] = h
        try:
            resp = requests.request(method, url, **kwargs)
            if RICH:
                color = "green" if resp.status_code < 300 else "yellow" if resp.status_code < 400 else "red"
                _console.print(Panel(
                    f"[bold {color}]{resp.status_code} {resp.reason}[/]\n"
                    f"[dim]Content-Type:[/] {resp.headers.get('content-type', '?')}\n"
                    f"[dim]Size:[/] {len(resp.content)} bytes",
                    title=f"{_method_badge(method)} [bold]{url}[/]",
                    border_style="#2a2a3a",
                ))
                try:
                    body_text = resp.text[:2000]
                    ct = resp.headers.get("content-type", "")
                    if "json" in ct:
                        syn = Syntax(json.dumps(resp.json(), indent=2)[:2000], "json",
                                     theme="one-dark", line_numbers=False)
                        _console.print(syn)
                    elif "html" in ct:
                        syn = Syntax(body_text, "html", theme="one-dark", line_numbers=False)
                        _console.print(syn)
                    else:
                        _console.print(body_text)
                except Exception:
                    _console.print("[dim][binary content][/]")
            else:
                print(f"Status: {resp.status_code} {resp.reason}")
                print(f"Content-Type: {resp.headers.get('content-type', '?')}")
                print(f"Size: {len(resp.content)} bytes")
                print("-" * 60)
                try:
                    print(resp.text[:1000])
                except Exception:
                    print("[binary]")
        except requests.exceptions.RequestException as e:
            _err(f"Request failed: {e}")

    def get_url(self, identifier):
        _, info = self._require_route(identifier)
        url = f"{self.server_url}{info['path']}"
        print(url)
        return url

    def export_routes(self, output_file=None, password=None):
        routes = self.get_routes()
        export_data = {
            "version":    1,
            "exportedAt": time.strftime("%Y-%m-%dT%H:%M:%SZ"),
            "routes": [{
                "path":               r["path"],
                "name":               r["name"],
                "category":           r["category"],
                "contentType":        r["contentType"],
                "contentEncoding":    r.get("contentEncoding", "text"),
                "content":            r["content"],
                "tags":               r.get("tags", []),
                "corsConfig":         r.get("corsConfig", {}),
                "customHeaders":      r.get("customHeaders", []),
                "fileName":           r.get("fileName", ""),
                "contentDisposition": r.get("contentDisposition", ""),
            } for r in routes],
        }
        if password:
            output_data = _encrypt_export(json.dumps(export_data), password)
        else:
            output_data = export_data

        out = output_file or "hoster-export.json"
        with open(out, "w") as f:
            json.dump(output_data, f, indent=2)
        _ok(f"Exported {len(routes)} route(s) → {out}")

    def import_routes(self, input_file, password=None, overwrite=False):
        if not os.path.exists(input_file):
            _err(f"File not found: {input_file}")
            sys.exit(1)
        with open(input_file, "r") as f:
            payload = json.load(f)

        if payload.get("encrypted"):
            if not password:
                _err("Export is encrypted — provide --password")
                sys.exit(1)
            try:
                data = json.loads(_decrypt_export(payload, password))
            except Exception as e:
                _err(f"Decryption failed: {e}")
                sys.exit(1)
        else:
            data = payload

        routes = data.get("routes", [])
        existing = {r["path"]: r["_id"] for r in self.get_routes()}
        created = updated = skipped = errors = 0

        for r in routes:
            try:
                if r["path"] in existing:
                    if overwrite:
                        self._request("PUT", f"/routes/{existing[r['path']]}", {
                            "name":               r["name"],
                            "contentType":        r["contentType"],
                            "contentEncoding":    r.get("contentEncoding", "text"),
                            "content":            r["content"],
                            "tags":               r.get("tags", []),
                            "customHeaders":      r.get("customHeaders", []),
                            "fileName":           r.get("fileName", ""),
                            "contentDisposition": r.get("contentDisposition", ""),
                        })
                        updated += 1
                    else:
                        skipped += 1
                else:
                    self._request("POST", "/routes", {
                        "path":               r["path"],
                        "name":               r["name"],
                        "category":           r.get("category", "classic"),
                        "contentType":        r["contentType"],
                        "contentEncoding":    r.get("contentEncoding", "text"),
                        "content":            r["content"],
                        "tags":               r.get("tags", []),
                        "customHeaders":      r.get("customHeaders", []),
                        "fileName":           r.get("fileName", ""),
                        "contentDisposition": r.get("contentDisposition", ""),
                    })
                    created += 1
            except Exception as e:
                _err(f"  {r['path']}: {e}")
                errors += 1

        _ok(f"Import done — created: {created}, updated: {updated}, skipped: {skipped}, errors: {errors}")

    def watch_logs(self, route_filter=None):
        filter_label = f" for {route_filter}" if route_filter else ""
        _info(f"Watching logs{filter_label}… (Ctrl+C to stop)")

        filter_path = None
        if route_filter:
            _, info = self._require_route(route_filter)
            filter_path = info.get("path", "")
        last_ts = None
        try:
            while True:
                result = self._request("GET", "/logs")
                logs = result.get("logs", result) if isinstance(result, dict) else result
                if isinstance(logs, list):
                    if filter_path:
                        logs = [l for l in logs if l.get("path", "") == filter_path]
                    logs.sort(key=lambda x: x.get("timestamp", ""), reverse=True)
                    new = [l for l in logs
                           if last_ts is None or l.get("timestamp", "") > last_ts]
                    if new:
                        last_ts = new[0].get("timestamp", "")
                        for log in reversed(new):
                            ts     = log.get("timestamp", "")
                            ip     = log.get("ip", "?")
                            method = log.get("method", "GET")
                            if RICH:
                                _console.rule(
                                    f"{_method_badge(method)} [bold #22d3ee]{ip}[/]  "
                                    f"[dim]{ts}[/]",
                                    style="#2a2a3a",
                                )
                                raw = log.get("rawRequest", "")
                                if raw:
                                    _console.print(raw, style="#94a3b8")
                            else:
                                print(f"\n[{ts}] {ip} — {method}")
                                print(log.get("rawRequest", ""))
                time.sleep(1)
        except KeyboardInterrupt:
            _info("Stopped.")

    def check_connection(self):
        try:
            routes = self.get_routes()
            return True, len(routes)
        except SystemExit:
            return False, 0

class HosterTUI:
    def __init__(self, client: HosterClient):
        self.c = client

    def _ask(self, fn, *args, **kwargs):
        kwargs.setdefault("style", _TUI_STYLE)
        try:
            result = fn(*args, **kwargs).ask()
            if result is None:
                raise KeyboardInterrupt
            return result
        except KeyboardInterrupt:
            _info("Cancelled.")
            return None

    def run(self):
        if not RICH or not QUESTIONARY:
            _err("TUI requires: pip install rich questionary")
            sys.exit(1)

        ok, n_routes = self.c.check_connection()
        _console.print(Panel(
            f"[bold #6366f1]Hoster[/] [dim]— Payload Hosting Manager[/]\n"
            f"[dim]Server:[/] {self.c.server_url}\n"
            f"[dim]Routes:[/] {n_routes if ok else '[red]unreachable[/]'}",
            border_style="#2a2a3a", padding=(0, 2),
        ))

        MENU = [
            ("📋  List Routes",         self.ui_list),
            ("⬆   Upload",              self.ui_upload),
            ("✏   Edit Route",          self.ui_edit),
            ("🗑   Delete Route",        self.ui_delete),
            ("📋→  Clone Route",         self.ui_clone),
            ("▶   Test Route",          self.ui_test),
            ("🏷   Tag / Untag",         self.ui_tag),
            ("🔒  CORS",                self.ui_cors),
            ("📤  Export",              self.ui_export),
            ("📥  Import",              self.ui_import),
            ("📡  Watch Logs",          self.c.watch_logs),
            ("⚙   Settings",            self.ui_settings),
            ("✖   Quit",               None),
        ]
        choices = [m[0] for m in MENU]

        while True:
            choice = self._ask(questionary.select, "What do you want to do?", choices=choices)
            if choice is None or choice == choices[-1]:
                break
            for label, fn in MENU:
                if label == choice and fn:
                    try:
                        fn()
                    except SystemExit:
                        pass
                    break

    def _select_route(self, prompt="Select a route"):
        routes = self.c.get_routes()
        if not routes:
            _info("No routes available.")
            return None
        choices = [f"{r['path']}  [{r.get('contentType','?')}]  {r['name']}"
                   for r in routes]
        choice = self._ask(questionary.select, prompt, choices=choices + ["↩ Back"])
        if not choice or choice == "↩ Back":
            return None
        idx = choices.index(choice)
        return routes[idx]

    def ui_list(self):
        tag = self._ask(questionary.text, "Filter by tag (leave blank for all):")
        if tag is None:
            return
        routes = self.c.list_routes(tag=tag.strip() or None)
        if routes:
            route = self._select_route("Open a route for details / actions?")
            if route:
                self._route_actions(route)

    def _route_actions(self, route):
        ACTIONS = [
            "🌐  Open URL",
            "▶   Test",
            "✏   Edit",
            "📋→  Clone",
            "🗑   Delete",
            "↩  Back",
        ]
        action = self._ask(questionary.select,
                           f"Actions for {route['path']}:", choices=ACTIONS)
        if not action or "Back" in action:
            return
        if "URL" in action:
            print(f"{self.c.server_url}{route['path']}")
        elif "Test" in action:
            method = self._ask(questionary.select, "Method:",
                               choices=["GET", "POST", "PUT", "DELETE", "PATCH"])
            if method:
                self.c.test_route(route["_id"], method=method)
        elif "Edit" in action:
            self._do_edit(route["_id"], route["path"])
        elif "Clone" in action:
            new_path = self._ask(questionary.text,
                                 "New path (leave blank for random):")
            if new_path is not None:
                self.c.clone_route(route["_id"], new_path.strip() or None)
        elif "Delete" in action:
            confirm = self._ask(questionary.confirm,
                                f"Delete {route['path']}?", default=False)
            if confirm:
                self.c.delete_route(route["_id"])

    def ui_upload(self):
        mode = self._ask(questionary.select, "Upload mode:",
                         choices=["Text / inline content", "Text file (text/base64/hex)", "Binary file (file mode)", "↩ Back"])
        if not mode or "Back" in mode:
            return

        path_in = self._ask(questionary.text, "Route path (blank = random):")
        if path_in is None:
            return
        path_in = path_in.strip() or None
        tags_in = self._ask(questionary.text, "Tags (comma-separated, optional):")
        if tags_in is None:
            return
        tags = [t.strip() for t in tags_in.split(",") if t.strip()]
        permanent = self._ask(questionary.confirm, "Permanent route?", default=False)

        if "inline" in mode:
            ct = self._ask(questionary.text, "Content-Type (blank = text/plain):")
            content = self._ask(questionary.text, "Content:")
            if content is None:
                return
            self.c.upload_content(content, ct or None, permanent, path_in, tags)

        elif "Text file" in mode:
            file_path = self._ask(questionary.path, "File path:")
            if not file_path or not os.path.exists(file_path):
                _err("File not found.")
                return
            enc = self._ask(questionary.select, "Encoding:",
                            choices=["text", "base64", "hex"])
            if enc is None:
                return
            self.c.upload_file_text(file_path, permanent=permanent,
                                    path=path_in, tags=tags, encoding=enc)

        elif "Binary" in mode:
            file_path = self._ask(questionary.path, "File path:")
            if not file_path or not os.path.exists(file_path):
                _err("File not found.")
                return
            cd_mode = self._ask(questionary.select, "Content-Disposition:",
                                choices=["attachment (auto)", "inline", "none", "custom"])
            if cd_mode is None:
                return
            if "auto" in cd_mode:
                cd = None
            elif cd_mode == "inline":
                cd = "inline"
            elif cd_mode == "none":
                cd = ""
            else:
                cd = self._ask(questionary.text, 'Custom value (e.g. attachment; filename="x.pdf"):')
            self.c.upload_file_binary(file_path, permanent=permanent,
                                      path=path_in, tags=tags,
                                      content_disposition=cd)

    def ui_edit(self):
        route = self._select_route("Select route to edit:")
        if not route:
            return
        self._do_edit(route["_id"], route["path"])

    def _do_edit(self, rid, rpath):
        fields = self._ask(questionary.checkbox, f"What to edit on {rpath}?",
                           choices=["name", "path", "content-type", "category", "tags", "content-disposition"])
        if not fields:
            return
        data = {}
        if "name" in fields:
            v = self._ask(questionary.text, "New name:")
            if v:
                data["name"] = v
        if "path" in fields:
            v = self._ask(questionary.text, "New path:")
            if v:
                data["path"] = v if v.startswith("/") else "/" + v
        if "content-type" in fields:
            v = self._ask(questionary.text, "New content-type (shortcut or full MIME):")
            if v:
                data["contentType"] = CONTENT_TYPE_SHORTCUTS.get(v, v)
        if "category" in fields:
            v = self._ask(questionary.select, "Category:", choices=["classic", "temporary"])
            if v:
                data["category"] = v
        if "tags" in fields:
            v = self._ask(questionary.text, "Tags (comma-separated, replaces all):")
            if v is not None:
                data["tags"] = [t.strip() for t in v.split(",") if t.strip()]
        if "content-disposition" in fields:
            v = self._ask(questionary.text, "Content-Disposition value (blank = none):")
            if v is not None:
                data["contentDisposition"] = v
        if data:
            self.c._request("PUT", f"/routes/{rid}", data)
            _ok(f"Route updated: {rpath}")

    def ui_delete(self):
        route = self._select_route("Select route to delete:")
        if not route:
            return
        confirm = self._ask(questionary.confirm,
                            f"Delete {route['path']}?", default=False)
        if confirm:
            self.c.delete_route(route["_id"])

    def ui_clone(self):
        route = self._select_route("Select route to clone:")
        if not route:
            return
        new_path = self._ask(questionary.text, "New path (blank = random):")
        if new_path is None:
            return
        self.c.clone_route(route["_id"], new_path.strip() or None)

    def ui_test(self):
        route = self._select_route("Select route to test:")
        if not route:
            return
        method = self._ask(questionary.select, "Method:",
                           choices=["GET", "POST", "PUT", "DELETE", "PATCH"])
        if not method:
            return
        self.c.test_route(route["_id"], method=method)

    def ui_tag(self):
        route = self._select_route("Select route:")
        if not route:
            return
        action = self._ask(questionary.select, "Action:",
                           choices=["Add tag", "Remove tag", "↩ Back"])
        if not action or "Back" in action:
            return
        tag = self._ask(questionary.text, "Tag:")
        if not tag:
            return
        self.c.tag_route(route["_id"], tag.strip(), remove="Remove" in action)

    def ui_cors(self):
        route = self._select_route("Select route:")
        if not route:
            return
        cors = route.get("corsConfig", {})
        _info(f"Current: enabled={cors.get('enabled',False)}, "
              f"origin={cors.get('allowOrigin','*')}")
        action = self._ask(questionary.select, "Action:",
                           choices=["Enable / update", "Disable", "↩ Back"])
        if not action or "Back" in action:
            return
        if "Disable" in action:
            self.c.set_cors(route["_id"], disable=True)
        else:
            origin  = self._ask(questionary.text,
                                f"Allow-Origin (current: {cors.get('allowOrigin','*')}):")
            methods = self._ask(questionary.text,
                                f"Allow-Methods (current: {cors.get('allowMethods','')}):")
            headers = self._ask(questionary.text,
                                f"Allow-Headers (current: {cors.get('allowHeaders','')}):")
            self.c.set_cors(route["_id"],
                            origin=origin or None,
                            methods=methods or None,
                            allow_headers=headers or None)

    def ui_export(self):
        out  = self._ask(questionary.text, "Output file (blank = hoster-export.json):")
        pwd  = self._ask(questionary.password, "Password (blank = no encryption):")
        if out is None:
            return
        self.c.export_routes(out.strip() or None, pwd.strip() or None)

    def ui_import(self):
        inp = self._ask(questionary.path, "Import file:")
        if not inp or not os.path.exists(inp):
            _err("File not found.")
            return
        pwd = self._ask(questionary.password, "Password (blank = not encrypted):")
        if pwd is None:
            return
        overwrite = self._ask(questionary.confirm,
                              "Overwrite existing routes?", default=False)
        self.c.import_routes(inp, pwd.strip() or None, overwrite)

    def ui_settings(self):
        _info(f"Server:   {self.c.server_url}")
        _info(f"API path: {self.c.api_path}")
        _info(f"API key:  {self.c.api_key[:8]}…" if self.c.api_key else "Not set")
        reconf = self._ask(questionary.confirm, "Reconfigure?", default=False)
        if reconf:
            key    = self._ask(questionary.password, "API Key:")
            server = self._ask(questionary.text,     "Server URL:")
            apath  = self._ask(questionary.text,     "API path (default /api/v1):")
            if key and server:
                self.c.save_config(key, server, apath.strip() or "/api/v1")

def _parse_headers(raw):
    """Parse list of 'Key: Value' strings into [{"key":..,"value":..}]."""
    result = []
    for h in (raw or []):
        if ":" in h:
            k, _, v = h.partition(":")
            result.append({"key": k.strip(), "value": v.strip()})
    return result

_COMMANDS = [
    "ui", "setup", "up", "ls", "rm", "edit", "url", "clone",
    "tag", "untag", "cors", "headers", "test", "export", "import",
    "logs", "open", "completion",
]

_BASH_COMPLETION = """\
_hoster_completion() {
    local cur prev words cword
    _init_completion || return
    local commands="{cmds}"
    if [[ $cword -eq 1 ]]; then
        COMPREPLY=( $(compgen -W "$commands" -- "$cur") )
        return
    fi
    case "$prev" in
        up) COMPREPLY=( $(compgen -f -- "$cur") ) ;;
        open|rm|edit|url|clone|tag|untag|cors|headers|test|logs)
            COMPREPLY=( $(hoster ls --names-only 2>/dev/null | compgen -W "$(cat)" -- "$cur") ) ;;
    esac
}
complete -F _hoster_completion hoster
"""

_ZSH_COMPLETION = """\

_hoster() {
    local -a commands
    commands=({cmds_zsh})
    _arguments '1: :->cmd' '*: :->args'
    case $state in
        cmd) _describe 'command' commands ;;
        args)
            case $words[2] in
                up) _files ;;
                open|rm|edit|url|clone|tag|untag|cors|headers|test|logs)
                    local routes
                    routes=( $(hoster ls --names-only 2>/dev/null) )
                    _describe 'route' routes ;;
            esac
            ;;
    esac
}
_hoster
"""

def _print_completion(shell):
    cmds = " ".join(_COMMANDS)
    cmds_zsh = " ".join(f'"{c}"' for c in _COMMANDS)
    if shell == "zsh":
        print(_ZSH_COMPLETION.format(cmds_zsh=cmds_zsh))
    else:
        print(_BASH_COMPLETION.format(cmds=cmds))
    if RICH:
        _console.print(
            f"\n[dim]Add to your ~/.{shell}rc:[/]\n"
            f"[bold]  eval \"$(hoster completion --shell {shell})\"[/]",
        )
    else:
        print(f"\n# Add to your ~/.{shell}rc:")
        print(f'#   eval "$(hoster completion --shell {shell})"')

def main():
    parser = argparse.ArgumentParser(
        prog="hoster",
        description="Hoster CLI — Payload Hosting Tool",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="cmd", metavar="<command>")

    sub.add_parser("ui", help="Interactive TUI mode")

    p = sub.add_parser("setup", help="Configure the client")
    p.add_argument("--key",      required=True, help="API key")
    p.add_argument("--server",   required=True, help="Server URL")
    p.add_argument("--api-path", default="/api/v1")

    p = sub.add_parser("up", help="Upload file or content")
    p.add_argument("file",           nargs="?", help="File path")
    p.add_argument("-c", "--content",            help="Inline content string")
    p.add_argument("--stdin",        action="store_true")
    p.add_argument("--ct", "--content-type",     dest="content_type")
    p.add_argument("--path",                     help="Route path")
    p.add_argument("--permanent",    action="store_true")
    p.add_argument("--tags",                     help="Comma-separated tags")
    p.add_argument("--base64",       dest="force_base64", action="store_true",
                   help="Encode as base64 text (user edits raw base64)")
    p.add_argument("--hex",          dest="force_hex", action="store_true",
                   help="Encode as hex text (user edits raw hex)")
    p.add_argument("--file-mode",    dest="file_mode", action="store_true",
                   help="Upload as binary file (encoding: file, served raw)")
    p.add_argument("--disposition",  dest="content_disposition",
                   help="Content-Disposition header value")
    p.add_argument("-H", "--header", dest="headers", action="append",
                   metavar="Key: Value", help="Custom response header (repeatable)")
    p.add_argument("--watch", action="store_true",
                   help="Watch the file and re-upload on change (polls every second)")

    p = sub.add_parser("ls", help="List routes")
    p.add_argument("--tag",        help="Filter by tag")
    p.add_argument("--search",     help="Search in all fields")
    p.add_argument("--names-only", action="store_true",
                   help="Print only route names/paths (one per line, for shell completion)")

    p = sub.add_parser("rm", help="Delete a route")
    p.add_argument("route")

    p = sub.add_parser("edit", help="Edit a route")
    p.add_argument("route")
    p.add_argument("-c",  "--content")
    p.add_argument("-f",  "--file")
    p.add_argument("-n",  "--name")
    p.add_argument("--category", choices=["temporary", "classic"])
    p.add_argument("--ct", "--content-type", dest="content_type")
    p.add_argument("--path")
    p.add_argument("--tags",        help="Comma-separated tags (replaces all)")
    p.add_argument("--disposition", dest="content_disposition",
                   help="Content-Disposition header")
    p.add_argument("-H", "--header", dest="headers", action="append",
                   metavar="Key: Value")

    p = sub.add_parser("url", help="Print URL of a route")
    p.add_argument("route")

    p = sub.add_parser("clone", help="Clone a route")
    p.add_argument("route")
    p.add_argument("--path", help="New path (random if omitted)")

    for cmd, help_text in [("tag", "Add a tag"), ("untag", "Remove a tag")]:
        p = sub.add_parser(cmd, help=help_text)
        p.add_argument("route")
        p.add_argument("tag")

    p = sub.add_parser("cors", help="Configure CORS on a route")
    p.add_argument("route")
    p.add_argument("--origin")
    p.add_argument("--methods")
    p.add_argument("--headers", dest="allow_headers")
    p.add_argument("--disable", action="store_true")

    p = sub.add_parser("headers", help="Configure custom response headers on a route")
    p.add_argument("route")
    p.add_argument("-H", "--header", dest="headers", action="append",
                   required=True, metavar="Key: Value",
                   help="Header to set (repeatable). e.g. -H 'X-Custom: value'")
    p.add_argument("--replace", action="store_true",
                   help="Replace all existing headers instead of merging")

    p = sub.add_parser("test", help="Test a route with an HTTP request")
    p.add_argument("route")
    p.add_argument("--method", "-X", default="GET",
                   choices=["GET", "POST", "PUT", "DELETE", "PATCH"])
    p.add_argument("--body", "-d")
    p.add_argument("-H", "--header", dest="headers", action="append",
                   metavar="Key: Value")

    p = sub.add_parser("export", help="Export all routes to JSON")
    p.add_argument("output",   nargs="?", help="Output file")
    p.add_argument("--password")

    p = sub.add_parser("import", help="Import routes from JSON")
    p.add_argument("input",    help="JSON export file")
    p.add_argument("--password")
    p.add_argument("--overwrite", action="store_true")

    p = sub.add_parser("logs", help="Watch access logs live")
    p.add_argument("route", nargs="?", help="Route name or path (optional)")

    p = sub.add_parser("open", help="Open route URL in the default browser")
    p.add_argument("route")

    p = sub.add_parser("completion", help="Print shell completion script")
    p.add_argument("--shell", choices=["bash", "zsh"], default="bash")

    args = parser.parse_args()
    client = HosterClient()

    if not args.cmd:
        if sys.stdin.isatty():
            HosterTUI(client).run()
        else:
            parser.print_help()
        return

    if args.cmd == "ui":
        HosterTUI(client).run()

    elif args.cmd == "setup":
        client.save_config(args.key, args.server, args.api_path)
        ok, n = client.check_connection()
        if ok:
            _ok(f"Connected — {n} route(s) found.")
        else:
            _warn("Could not connect to server.")

    elif args.cmd == "up":
        tags = [t.strip() for t in args.tags.split(",")] if args.tags else []
        custom_headers = _parse_headers(args.headers)
        cd = args.content_disposition if hasattr(args, "content_disposition") else None

        watch_mode = getattr(args, "watch", False) and args.file
        if watch_mode and not args.path:
            args.path = client._random_path()

        if args.stdin:
            content = sys.stdin.read()
            client.upload_content(content, args.content_type, args.permanent,
                                  args.path, tags, custom_headers=custom_headers)
        elif args.content:
            client.upload_content(args.content, args.content_type, args.permanent,
                                  args.path, tags, custom_headers=custom_headers)
        elif args.file:
            if args.file_mode:
                client.upload_file_binary(args.file, args.content_type, args.permanent,
                                          args.path, tags, content_disposition=cd,
                                          custom_headers=custom_headers)
            elif args.force_base64:
                client.upload_file_text(args.file, args.content_type, args.permanent,
                                        args.path, tags, encoding="base64",
                                        custom_headers=custom_headers)
            elif args.force_hex:
                client.upload_file_text(args.file, args.content_type, args.permanent,
                                        args.path, tags, encoding="hex",
                                        custom_headers=custom_headers)
            else:

                try:
                    client.upload_file_text(args.file, args.content_type, args.permanent,
                                            args.path, tags, encoding="text",
                                            custom_headers=custom_headers)
                except SystemExit:
                    _info("Auto-switching to binary file mode…")
                    client.upload_file_binary(args.file, args.content_type, args.permanent,
                                              args.path, tags, content_disposition=cd,
                                              custom_headers=custom_headers)
        else:
            _err("Provide a file path, -c content, or --stdin")
            sys.exit(1)

        if watch_mode:
            _info(f"Watching {args.file} for changes… (Ctrl+C to stop)")
            rid, _ = client._require_route(args.path)
            last_mtime = os.stat(args.file).st_mtime
            encoding = "base64" if args.force_base64 else "hex" if args.force_hex else \
                       "file" if args.file_mode else "text"
            try:
                while True:
                    time.sleep(1)
                    mtime = os.stat(args.file).st_mtime
                    if mtime != last_mtime:
                        last_mtime = mtime
                        _info(f"Change detected — re-uploading {args.file}…")
                        try:
                            if encoding in ("base64", "file"):
                                with open(args.file, "rb") as f:
                                    new_content = base64.b64encode(f.read()).decode("ascii")
                            elif encoding == "hex":
                                with open(args.file, "rb") as f:
                                    new_content = f.read().hex()
                            else:
                                with open(args.file, "r", encoding="utf-8") as f:
                                    new_content = f.read()
                            client._request("PUT", f"/routes/{rid}", {"content": new_content})
                            _ok("Updated.")
                        except Exception as e:
                            _warn(f"Re-upload failed: {e}")
            except KeyboardInterrupt:
                _info("Watch stopped.")

    elif args.cmd == "ls":
        if getattr(args, "names_only", False):
            routes = client.get_routes()
            for r in routes:
                print(r.get("name") or r.get("path", ""))
        else:
            client.list_routes(
                tag=args.tag if hasattr(args, "tag") else None,
                search=args.search if hasattr(args, "search") else None,
            )

    elif args.cmd == "rm":
        client.delete_route(args.route)

    elif args.cmd == "edit":
        content = args.content
        if args.file:
            with open(args.file, "r") as f:
                content = f.read()
        custom_headers = _parse_headers(args.headers)
        client.edit_route(
            args.route,
            content=content,
            name=args.name,
            category=args.category,
            content_type=args.content_type,
            path=args.path,
            tags=args.tags,
            content_disposition=args.content_disposition if hasattr(args, "content_disposition") else None,
            customHeaders=custom_headers if custom_headers else None,
        )

    elif args.cmd == "url":
        client.get_url(args.route)

    elif args.cmd == "clone":
        client.clone_route(args.route, args.path if hasattr(args, "path") else None)

    elif args.cmd == "tag":
        client.tag_route(args.route, args.tag)

    elif args.cmd == "untag":
        client.tag_route(args.route, args.tag, remove=True)

    elif args.cmd == "cors":
        client.set_cors(
            args.route, args.origin, args.methods,
            args.allow_headers if hasattr(args, "allow_headers") else None,
            args.disable,
        )

    elif args.cmd == "headers":
        client.set_headers(args.route, args.headers, replace=args.replace)

    elif args.cmd == "test":
        client.test_route(args.route, args.method, args.body, args.headers)

    elif args.cmd == "export":
        client.export_routes(args.output, args.password)

    elif args.cmd == "import":
        client.import_routes(args.input, args.password, args.overwrite)

    elif args.cmd == "logs":
        client.watch_logs(route_filter=getattr(args, "route", None))

    elif args.cmd == "open":
        _, info = client._require_route(args.route)
        url = f"{client.server_url}{info['path']}"
        _info(f"Opening {url}")
        webbrowser.open(url)

    elif args.cmd == "completion":
        _print_completion(args.shell)

    else:
        parser.print_help()

if __name__ == "__main__":
    main()
