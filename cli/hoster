class HosterClient:
    def __init__(self):
        self.config = configparser.ConfigParser()
        self.api_key = None
        self.server_url = None
        self.api_path = "/api/v1"
        self._load_config()

    def _load_config(self):
        if os.path.exists(CONFIG_FILE):
            self.config.read(CONFIG_FILE)
            d = self.config["DEFAULT"]
            if d.get("api_key"):
                self.api_key    = d.get("api_key")
                self.server_url = d.get("server_url", "").rstrip("/")
                self.api_path   = d.get("api_path", "/api/v1")
                if not self.api_path.startswith("/"):
                    self.api_path = "/" + self.api_path

    def save_config(self, api_key, server_url, api_path="/api/v1"):
        self.api_key    = api_key
        self.server_url = server_url.rstrip("/")
        self.api_path   = api_path if api_path.startswith("/") else "/" + api_path
        self.config["DEFAULT"] = {
            "api_key":    self.api_key,
            "server_url": self.server_url,
            "api_path":   self.api_path,
        }
        with open(CONFIG_FILE, "w") as f:
            self.config.write(f)
        _ok(f"Config saved to {CONFIG_FILE}")

    def _request(self, method, endpoint, data=None, params=None):
        if not self.api_key or not self.server_url:
            _err("Not configured. Run: hoster setup --key <key> --server <url>")
            sys.exit(1)
        ep = endpoint if endpoint.startswith("/") else "/" + endpoint
        url = f"{self.server_url}{self.api_path}{ep}"
        headers = {"X-API-Key": self.api_key, "Content-Type": "application/json"}
        try:
            resp = requests.request(method, url, json=data, headers=headers,
                                    params=params, timeout=15)
            resp.raise_for_status()
            return resp.json() if resp.content else {}
        except requests.exceptions.RequestException as e:
            if hasattr(e, "response") and e.response is not None:
                try:
                    msg = e.response.json().get("message", e.response.text)
                except Exception:
                    msg = e.response.text
                _err(f"API error: {msg}")
            else:
                _err(f"Request error: {e}")
            sys.exit(1)

    def get_routes(self, tag=None, search=None):
        params = {}
        if tag:    params["tag"]    = tag
        if search: params["search"] = search
        return self._request("GET", "/routes", params=params)

    def find_route(self, identifier):
        """Find route by name, path, or ID prefix."""
        routes = self.get_routes()
        for r in routes:
            if r["_id"] == identifier:
                return r["_id"], r
        for r in routes:
            if r["path"] == identifier or r["path"] == "/" + identifier:
                return r["_id"], r
        for r in routes:
            if r["name"] == identifier:
                return r["_id"], r
        for r in routes:
            if r["_id"].startswith(identifier):
                return r["_id"], r
        return None, None

    def _require_route(self, identifier):
        rid, info = self.find_route(identifier)
        if not rid:
            _err(f"Route not found: {identifier}")
            sys.exit(1)
        return rid, info

    def _random_path(self, length=8):
        return "/" + "".join(random.choices(string.ascii_lowercase + string.digits, k=length))

    def _ct_from_file(self, path, forced=None):
        if forced:
            if "/" in forced:
                return forced
            return CONTENT_TYPE_SHORTCUTS.get(forced.lower(), DEFAULT_CONTENT_TYPE)
        ext = os.path.splitext(path)[1].lower()
        return CONTENT_TYPES.get(ext, DEFAULT_CONTENT_TYPE)

    def upload_content(self, content, content_type=None, permanent=False,
                       path=None, tags=None, encoding="text",
                       custom_headers=None, content_disposition=None):
        ct = CONTENT_TYPE_SHORTCUTS.get(content_type, content_type) if content_type else DEFAULT_CONTENT_TYPE
        route_path = path if path else self._random_path()
        if not route_path.startswith("/"):
            route_path = "/" + route_path
        data = {
            "path":               route_path,
            "name":               route_path.lstrip("/") or "route",
            "contentType":        ct,
            "contentEncoding":    encoding,
            "content":            content,
            "category":           "classic" if permanent else "temporary",
            "tags":               tags or [],
            "customHeaders":      custom_headers or [],
            "contentDisposition": content_disposition or "",
        }
        self._request("POST", "/routes", data)
        url = f"{self.server_url}{route_path}"
        if RICH:
            _console.print(f"[bold green]{url}[/]")
        else:
            print(url)
        return url

    def upload_file_text(self, file_path, content_type=None, permanent=False,
                         path=None, tags=None, encoding="text",
                         custom_headers=None, content_disposition=None):
        """Upload a text file (encoding: text/base64/hex — content typed into editor)."""
        ct = self._ct_from_file(file_path, content_type)
        name = os.path.splitext(os.path.basename(file_path))[0]
        route_path = path if path else self._random_path()
        if not route_path.startswith("/"):
            route_path = "/" + route_path

        if encoding == "base64":
            with open(file_path, "rb") as f:
                content = base64.b64encode(f.read()).decode("ascii")
        elif encoding == "hex":
            with open(file_path, "rb") as f:
                content = f.read().hex()
        else:
            try:
                with open(file_path, "r", encoding="utf-8") as f:
                    content = f.read()
            except UnicodeDecodeError:
                _warn("Binary file detected — use --file-mode to serve as raw binary, or --base64/--hex for encoded text.")
                sys.exit(1)

        data = {
            "path":               route_path,
            "name":               name,
            "contentType":        ct,
            "contentEncoding":    encoding,
            "content":            content,
            "category":           "classic" if permanent else "temporary",
            "tags":               tags or [],
            "customHeaders":      custom_headers or [],
            "contentDisposition": content_disposition or "",
        }
        self._request("POST", "/routes", data)
        url = f"{self.server_url}{route_path}"
        if RICH:
            _console.print(f"[bold green]{url}[/]")
        else:
            print(url)
        return url

    def upload_file_binary(self, file_path, content_type=None, permanent=False,
                           path=None, tags=None,
                           content_disposition=None, custom_headers=None):
        """Upload a file in 'file' mode — served as raw binary."""
        if not os.path.exists(file_path):
            _err(f"File not found: {file_path}")
            sys.exit(1)
        ct = self._ct_from_file(file_path, content_type)
        file_name = os.path.basename(file_path)
        file_size = os.path.getsize(file_path)
        name = os.path.splitext(file_name)[0]
        route_path = path if path else self._random_path()
        if not route_path.startswith("/"):
            route_path = "/" + route_path

        with open(file_path, "rb") as f:
            content = base64.b64encode(f.read()).decode("ascii")

        cd = content_disposition
        if cd is None:
            cd = f'attachment; filename="{file_name}"'

        data = {
            "path":               route_path,
            "name":               name,
            "contentType":        ct,
            "contentEncoding":    "file",
            "content":            content,
            "fileName":           f"{file_name} ({file_size / 1024:.1f} KB)",
            "contentDisposition": cd,
            "category":           "classic" if permanent else "temporary",
            "tags":               tags or [],
            "customHeaders":      custom_headers or [],
        }
        self._request("POST", "/routes", data)
        url = f"{self.server_url}{route_path}"
        _info(f"File: {file_name} ({file_size / 1024:.1f} KB)")
        if RICH:
            _console.print(f"[bold green]{url}[/]")
        else:
            print(url)
        return url

