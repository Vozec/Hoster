{
  "name": "hoster-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol server exposing Hoster features (routes, logs, stats, config) to AI agents.",
  "type": "module",
  "main": "src/server.js",
  "bin": {
    "hoster-mcp": "src/server.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "start:stdio": "MCP_TRANSPORT=stdio node src/server.js",
    "start:http": "MCP_TRANSPORT=http node src/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "axios": "^1.7.7",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  }
}
